{
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "type": "AdaptiveCard",
    "version": "1.4",
    "body": [
        {
            "type": "Container",
            "style": "accent",
            "items": [
                {
                    "type": "TextBlock",
                    "text": "New Employee Onboarding Request",
                    "weight": "Bolder",
                    "size": "Large",
                    "color": "Dark"
                },
                {
                    "type": "TextBlock",
                    "text": "Please create an M365 account for this new employee and record the UPN below",
                    "size": "Small",
                    "color": "Dark",
                    "isSubtle": true,
                    "spacing": "None"
                },
                {
                    "type": "TextBlock",
                    "text": "Employee Name: {{EmployeeName}}",
                    "size": "Small",
                    "color": "Dark",
                    "isSubtle": true,
                    "spacing": "None"
                },
                {
                    "type": "TextBlock",
                    "text": "Request Id {{RequestId}}",
                    "size": "Small",
                    "color": "Dark",
                    "isSubtle": true,
                    "spacing": "None"
                }
            ],
            "bleed": true
        },
        {
            "type": "Container",
            "items": [
                {
                "type": "Input.Text",
                "id": "upn",
                "label": "UPN",
                "placeholder": "e.g. jane.smith@contoso.com",
                "style": "email",
                "isRequired": true,
                "errorMessage": "A valid UPN is required."
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Action.Submit",
            "title": "Submit",
            "style": "positive",
            "data": {
                "action": "submitUPN"
            }
        }
    ]
}